menu "App Config"

menu "Default Wi-Fi Settings"

    config APP_WIFI_SSID
        string "Default Wi-Fi SSID"
        default ""
        help
            Default Wi-Fi SSID used to populate app settings.

    config APP_WIFI_PASSWORD
        string "Default Wi-Fi password"
        default ""
        help
            Default Wi-Fi password used to populate app settings.

    config APP_WIFI_AP_SSID_PREFIX
        string "Provisioning AP SSID prefix"
        default "esp-claw"
        help
            Prefix used to build the unique provisioning AP SSID. The full
            SSID is "<prefix>-<MAC[3..5]>" (e.g. esp-claw-84AEE5).

    config APP_WIFI_AP_CHANNEL
        int "Provisioning AP channel"
        range 1 13
        default 1
        help
            Channel used by the provisioning SoftAP.

    config APP_WIFI_AP_MAX_CONN
        int "Provisioning AP max connections"
        range 1 10
        default 4
        help
            Maximum number of concurrent stations on the provisioning AP.

    config APP_WIFI_MAX_RETRY
        int "STA max retries before AP fallback"
        range 1 20
        default 5
        help
            After this many consecutive STA connection failures the device
            falls back to pure AP mode and waits for the user to provision
            new credentials.

endmenu

menu "AT UART1 Provisioning Notify"

    config APP_AT_UART1_NOTIFY_ENABLE
        bool "Enable UART1 provisioning notifications"
        default y
        depends on APP_CLAW_CAP_AT_MQTT
        help
            Send provisioning status lines to the host over UART1 when Wi-Fi
            state changes or when the device starts already connected.

    config APP_AT_UART1_TX_PIN
        int "UART1 AT TX pin"
        default 17
        depends on APP_AT_UART1_NOTIFY_ENABLE

    config APP_AT_UART1_RX_PIN
        int "UART1 AT RX pin"
        default 18
        depends on APP_AT_UART1_NOTIFY_ENABLE

    config APP_AT_UART1_BAUD
        int "UART1 AT baud rate"
        default 115200
        depends on APP_AT_UART1_NOTIFY_ENABLE

endmenu

endmenu
